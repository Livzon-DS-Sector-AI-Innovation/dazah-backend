# App
APP_NAME=dazah-backend
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dazah
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dazah
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# Docker app container only.
# Keep DATABASE_URL/REDIS_URL on localhost for local Windows development.
# The Compose app profile uses these container-network URLs instead.
APP_DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/dazah
APP_REDIS_URL=redis://redis:localhost:6379/0

# Audit
AUDIT_RETENTION_DAYS=7

# Feishu (Lark) Integration
FEISHU_APP_ID=YOUR_FEISHU_APP_ID
FEISHU_APP_SECRET=YOUR_FEISHU_APP_SECRET
FEISHU_BITABLE_APP_TOKEN=YOUR_BITABLE_APP_TOKEN
FEISHU_BITABLE_EMPLOYEE_TABLE_ID=tblEmployee
FEISHU_BITABLE_DEPARTMENT_TABLE_ID=tblDepartment
FEISHU_BITABLE_OFFBOARDING_TABLE_ID=tblOffboarding
FEISHU_BITABLE_ONBOARDING_TABLE_ID=tblOnboarding
FEISHU_BITABLE_DEPARTURE_TABLE_ID=tblDeparture
FEISHU_BITABLE_APPROVAL_TABLE_ID=tblApproval

# Feishu AI Query
FEISHU_AI_QUERY_TABLES={}
FEISHU_AI_QUERY_MAX_ROWS=200

# 安全模块 - 隐患登记多维表格同步
SAFETY_FEISHU_BITABLE_APP_TOKEN  = UKlobrKj3aQ24XsBRkTcqdL0nkc
SAFETY_FEISHU_BITABLE_HAZARD_TABLE_ID = tblB7D5BjNSOruaD

# 安全模块 - AI 模型配置（文本 / 视觉）
SAFETY_AI_TEXT_API_KEY           = sk-3b7d6bd5252246ff8af5f30a0f97b8f5
SAFETY_AI_TEXT_BASE_URL          = https://api.deepseek.com
SAFETY_AI_TEXT_MODEL             = deepseek-v4-flash
SAFETY_AI_VISION_API_KEY         = sk-a2ef55e9d2904572bb039f51e236a250
SAFETY_AI_VISION_BASE_URL        = https://dashscope.aliyuncs.com/compatible-mode/v1
SAFETY_AI_VISION_MODEL           = qwen-vl-max

# 设备模块 - 交互机器人
EQUIPMENT_FEISHU_WS_ENABLED=false
EQUIPMENT_FEISHU_APP_ID=***
EQUIPMENT_FEISHU_APP_SECRET=***

# Aily
AILY_APP_ID=your-aily-app-id

# AI
MOONSHOT_API_KEY=your-moonshot-api-key
AI_MODEL=kimi-k2.5

# MinIO / S3 对象存储（Docker 部署时启用，本地开发可关闭）
MINIO_ENABLED=false
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_PREFIX=dazah
MINIO_SECURE=false

# MCP AI Agent API Keys (comma separated, for service-to-service authentication)
MCP_AGENT_API_KEYS=
