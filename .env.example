# App
APP_NAME=dazah-backend
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production
# Optional Fernet key for encrypting secrets stored in DB.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dazah
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dazah
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# Docker app container only.
# Keep DATABASE_URL/REDIS_URL on localhost for local Windows development.
# The Compose app profile uses these container-network URLs instead.
APP_DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/dazah
APP_REDIS_URL=redis://redis:6379/0

# Audit
AUDIT_RETENTION_DAYS=7

# Feishu (Lark) - platform app shared by SSO, org sync, IM and common Bitable access.
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_REDIRECT_URI=http://localhost:8000/api/v1/identity/auth/callback
FEISHU_SCOPES=contact:contact.base:readonly contact:user.base:readonly
FRONTEND_URL=http://localhost:3000
FEISHU_WS_ENABLED=true

# Development-stage local login bootstrap.
# Leave blank to skip creating that account.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change-me-admin
BOOTSTRAP_ADMIN_NAME=系统管理员
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_USER_USERNAME=user
BOOTSTRAP_USER_PASSWORD=change-me-user
BOOTSTRAP_USER_NAME=普通用户
BOOTSTRAP_USER_EMAIL=user@example.com
# Comma-separated Feishu open_id/user_id/email/mobile/employee_no values promoted to admin.
SSO_ADMIN_IDENTIFIERS=

# Feishu org sync / common chat targets.
FEISHU_SYNC_ROOT_DEPT_ID=
FEISHU_SYNC_MEMBER_DEPT_ID=
FEISHU_EQUIPMENT_DEPT_ID=
FEISHU_EQUIPMENT_CHAT_ID=
FEISHU_SAFETY_CHAT_ID=

# Feishu Bitable - HR module.
FEISHU_BITABLE_APP_TOKEN=base_or_wiki_converted_app_token
FEISHU_BITABLE_EMPLOYEE_TABLE_ID=tblEmployee
FEISHU_BITABLE_DEPARTMENT_TABLE_ID=tblDepartment
FEISHU_BITABLE_OFFBOARDING_TABLE_ID=tblOffboarding
FEISHU_BITABLE_ONBOARDING_TABLE_ID=tblOnboarding
FEISHU_BITABLE_DEPARTURE_TABLE_ID=tblDeparture
FEISHU_BITABLE_APPROVAL_TABLE_ID=tblApproval

# Feishu Bitable - product module.
FEISHU_BITABLE_PRODUCT_APP_TOKEN=
FEISHU_BITABLE_PRODUCT_TABLE_ID=

# Feishu AI Query
FEISHU_AI_QUERY_TABLES={}
FEISHU_AI_QUERY_MAX_ROWS=200

# Safety module - independent Feishu app and hazard Bitable.
SAFETY_FEISHU_APP_ID=
SAFETY_FEISHU_APP_SECRET=
SAFETY_FEISHU_BITABLE_APP_TOKEN=
SAFETY_FEISHU_BITABLE_HAZARD_TABLE_ID=

# 安全模块 - AI 模型配置（文本 / 视觉）
SAFETY_AI_TEXT_API_KEY           = your_safety_text_api_key
SAFETY_AI_TEXT_BASE_URL          = https://api.deepseek.com
SAFETY_AI_TEXT_MODEL             = deepseek-v4-flash
SAFETY_AI_VISION_API_KEY         = your_safety_vision_api_key
SAFETY_AI_VISION_BASE_URL        = https://dashscope.aliyuncs.com/compatible-mode/v1
SAFETY_AI_VISION_MODEL           = qwen-vl-max

# 设备模块 - 交互机器人
EQUIPMENT_FEISHU_WS_ENABLED=false
EQUIPMENT_FEISHU_APP_ID=
EQUIPMENT_FEISHU_APP_SECRET=

# Aily
AILY_APP_ID=your-aily-app-id

# AI
MOONSHOT_API_KEY=your-moonshot-api-key
AI_MODEL=kimi-k2.5

# MinIO / S3 对象存储（Docker 部署时启用，本地开发可关闭）
MINIO_ENABLED=false
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_PREFIX=dazah
MINIO_SECURE=false

# MCP AI Agent API Keys (comma separated, for service-to-service authentication)
MCP_AGENT_API_KEYS=

# Hermes 中枢 Agent
# HERMES_AGENT_URL points to the Hermes-Lite Dazah adapter, for example:
# http://127.0.0.1:8100/v1/chat
HERMES_AGENT_URL=
HERMES_AGENT_TOKEN=
AGENT_TOOL_TOKEN=
AGENT_LLM_PROXY_TOKEN=
AGENT_INTERNAL_API_BASE_URL=http://127.0.0.1:8000/api/v1
AGENT_INTERNAL_API_TOKEN=
AGENT_WRITE_CONFIRM_TTL_SECONDS=300
