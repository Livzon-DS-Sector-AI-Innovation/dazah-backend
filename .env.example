# App
APP_NAME=dazah-backend
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production

# Database (SQLite — 数据库文件已包含在项目内)
DATABASE_URL=sqlite+aiosqlite:///./dazah.db

# Redis (可选，不使用 Redis 时留空或保持默认)
REDIS_URL=redis://localhost:6379/0

# Audit
AUDIT_RETENTION_DAYS=7

# Feishu (Lark) Integration — 如需同步飞书数据请填写
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_EMPLOYEE_TABLE_ID=
FEISHU_BITABLE_DEPARTMENT_TABLE_ID=
FEISHU_BITABLE_OFFBOARDING_TABLE_ID=
FEISHU_BITABLE_APPROVAL_TABLE_ID=

# AI
MOONSHOT_API_KEY=
