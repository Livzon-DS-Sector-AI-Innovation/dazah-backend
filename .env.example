# App
APP_NAME=dazah-backend
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dazah
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dazah
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# Docker app container only.
# Keep DATABASE_URL/REDIS_URL on localhost for local Windows development.
# The Compose app profile uses these container-network URLs instead.
APP_DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/dazah
APP_REDIS_URL=redis://redis:6379/0

# Audit
AUDIT_RETENTION_DAYS=7

# Crawler (法规追踪爬虫)
CRAWLER_HEADLESS=true
CRAWLER_BROWSERS_PATH=
CDE_GUIDELINE_URL=https://www.cde.org.cn/zdyz/listpage/9cd8db3b7530c6fa0c86485e563f93c7
DAILY_SYNC_CRON=0 2 * * *
