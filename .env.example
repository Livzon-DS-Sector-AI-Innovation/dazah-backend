# App
APP_NAME=dazah-backend
APP_ENV=development
DEBUG=false
SECRET_KEY=change-me-in-production

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dazah
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dazah
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# Docker app container only.
# Keep DATABASE_URL/REDIS_URL on localhost for local Windows development.
# The Compose app profile uses these container-network URLs instead.
APP_DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/dazah
APP_REDIS_URL=redis://redis:localhost:6379/0

# Feishu SSO — 必填，不设默认值
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_REDIRECT_URI=http://<your-server>/api/v1/identity/auth/callback
FRONTEND_URL=http://<your-server>

# Feishu 组织架构同步
# FEISHU_SYNC_ROOT_DEPT_ID: API POST /sync/departments 触发同步时的根部门
# FEISHU_SYNC_MEMBER_DEPT_ID: 每日 00:00 定时同步成员的目标部门
FEISHU_SYNC_ROOT_DEPT_ID=od-xxx
FEISHU_SYNC_MEMBER_DEPT_ID=od-xxx

# JWT
JWT_EXPIRE_SECONDS=86400

# Audit
AUDIT_RETENTION_DAYS=7

# Feishu (Lark) Integration
FEISHU_APP_ID=cli_a965af5f70525cb5
FEISHU_APP_SECRET=dW90FQW5h1SKDL6cOLdRUhcEcPkoCG0z
FEISHU_BITABLE_APP_TOKEN=YOUR_BITABLE_APP_TOKEN
FEISHU_BITABLE_EMPLOYEE_TABLE_ID=tblEmployee
FEISHU_BITABLE_DEPARTMENT_TABLE_ID=tblDepartment
FEISHU_BITABLE_OFFBOARDING_TABLE_ID=tblOffboarding

# Crawler (法规追踪爬虫)
CRAWLER_HEADLESS=true
CRAWLER_BROWSERS_PATH=
CDE_GUIDELINE_URL=https://www.cde.org.cn/zdyz/listpage/9cd8db3b7530c6fa0c86485e563f93c7
DAILY_SYNC_CRON=0 2 * * *

# LLM Configuration (DeepSeek API)
OPENAI_API_KEY=your-deepseek-api-key-here
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-v4-flash

# 安全模块 - 机器人
SAFETY_FEISHU_APP_ID=***
SAFETY_FEISHU_APP_SECRET=***

# 设备模块 - 交互机器人
EQUIPMENT_FEISHU_APP_ID=***
EQUIPMENT_FEISHU_APP_SECRET=***
EQUIPMENT_FEISHU_WS_ENABLED=false

# 设备模块 - 维护计划自动生成工单
MAINTENANCE_PLAN_AUTO_ENABLED=true

# HR 模块 — 飞书多维表格同步
FEISHU_BOT_NAME=
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_EMPLOYEE_TABLE_ID=
FEISHU_BITABLE_DEPARTMENT_TABLE_ID=
FEISHU_BITABLE_OFFBOARDING_TABLE_ID=
FEISHU_BITABLE_ONBOARDING_TABLE_ID=
FEISHU_BITABLE_DEPARTURE_TABLE_ID=
FEISHU_BITABLE_APPROVAL_TABLE_ID=

# HR 模块 — 培训通知多维表格
FEISHU_BITABLE_TRAINING_NOTIFICATION_APP_TOKEN=
FEISHU_BITABLE_TRAINING_NOTIFICATION_TABLE_ID=

# HR 模块 — AI 离职分析（Moonshot/Kimi API）
MOONSHOT_API_KEY=
AI_MODEL=kimi-k2.5

# MCP AI Agent API Keys (comma separated, for service-to-service authentication)
MCP_AGENT_API_KEYS=
