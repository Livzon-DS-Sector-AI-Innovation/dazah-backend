# App
APP_NAME=dazah-backend
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dazah
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dazah
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# Docker app container only.
# Keep DATABASE_URL/REDIS_URL on localhost for local Windows development.
# The Compose app profile uses these container-network URLs instead.
APP_DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/dazah
APP_REDIS_URL=redis://redis:localhost:6379/0

# Audit
AUDIT_RETENTION_DAYS=7

# ============================================================
# 飞书集成（多 Bot + 多 Base 架构）
# 说明：app_token / table_id 未配置时，对应同步逻辑会自动跳过(_is_enabled)，
#       不报错、不阻断启动。即下方除主 Bot 凭证外，按需配置即可。
# 详见 docs/数据源与飞书参考.md
# ============================================================

# —— 主 Bot（招聘 / HR 台账）——
FEISHU_BOT_NAME=YOUR_BOT_NAME
FEISHU_APP_ID=YOUR_FEISHU_APP_ID
FEISHU_APP_SECRET=YOUR_FEISHU_APP_SECRET
FEISHU_BITABLE_APP_TOKEN=YOUR_BITABLE_APP_TOKEN     # HR 主 Base
FEISHU_BITABLE_EMPLOYEE_TABLE_ID=tblEmployee
FEISHU_BITABLE_DEPARTMENT_TABLE_ID=tblDepartment
FEISHU_BITABLE_OFFBOARDING_TABLE_ID=tblOffboarding
FEISHU_BITABLE_ONBOARDING_TABLE_ID=tblOnboarding
FEISHU_BITABLE_DEPARTURE_TABLE_ID=tblDeparture
FEISHU_BITABLE_APPROVAL_TABLE_ID=tblApproval
FEISHU_BITABLE_CANDIDATE_APP_TOKEN=YOUR_CANDIDATE_BASE_TOKEN   # 招聘候选人，独立 Base
FEISHU_BITABLE_CANDIDATE_TABLE_ID=tblCandidate

# —— 车辆 Bot（行政用车）——可选，不配则用车同步跳过
FEISHU_VEHICLE_APP_ID=YOUR_VEHICLE_APP_ID
FEISHU_VEHICLE_APP_SECRET=YOUR_VEHICLE_APP_SECRET
FEISHU_BITABLE_VEHICLE_REQUEST_APP_TOKEN=YOUR_VEHICLE_BASE_TOKEN
FEISHU_BITABLE_VEHICLE_REQUEST_TABLE_ID=tblVehicleRequest

# —— 培训 Bot（培训通知 / 产品 / 物料 BOM）——可选
FEISHU_TRAINING_APP_ID=YOUR_TRAINING_APP_ID
FEISHU_TRAINING_APP_SECRET=YOUR_TRAINING_APP_SECRET
FEISHU_BITABLE_TRAINING_NOTIFICATION_APP_TOKEN=YOUR_TRAINING_BASE_TOKEN
FEISHU_BITABLE_TRAINING_NOTIFICATION_TABLE_ID=tblTrainingNotification
FEISHU_BITABLE_PRODUCT_APP_TOKEN=YOUR_PRODUCT_BASE_TOKEN
FEISHU_BITABLE_PRODUCT_TABLE_ID=tblProduct
FEISHU_BITABLE_MATERIAL_BOM_APP_TOKEN=YOUR_MATERIAL_BOM_BASE_TOKEN
FEISHU_BITABLE_MATERIAL_BOM_TABLE_ID=tblMaterialBom

# Feishu AI Query
FEISHU_AI_QUERY_TABLES={}
FEISHU_AI_QUERY_MAX_ROWS=200

# Aily
AILY_APP_ID=your-aily-app-id

# AI
MOONSHOT_API_KEY=your-moonshot-api-key
AI_MODEL=kimi-k2.5
AI_SYSTEM_PROMPT=YOUR_AI_SYSTEM_PROMPT     # AI 助手的系统提示词，可选
