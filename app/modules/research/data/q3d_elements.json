  "calculation_options": {
    "option_1": {
      "name": "选项1",
      "description": "日剂量≤10g的药品各组分中元素的通用允许浓度限度",
      "formula": "Concentration (μg/g) = PDE (μg/day) / 10 (g/day)",
      "applicability": "所有组分中目标元素浓度不超过选项1限度"
    },
    "option_2a": {
      "name": "选项2a",
      "description": "指定日剂量的药品各组分中元素的通用允许浓度限度",
      "formula": "Concentration (μg/g) = PDE (μg/day) / Actual Daily Intake (g/day)",
      "applicability": "使用实际最大日剂量计算"
    },
    "option_2b": {
      "name": "选项2b",
      "description": "指定日剂量的药品各组分中元素的允许浓度限度",
      "formula": "Σ(Ck × Mk) ≤ PDE",
      "variables": {
        "Ck": "组分k中元素允许浓度 (μg/g)",
        "Mk": "药品最大日剂量中组分k的质量 (g)"
      },
      "applicability": "基于元素在组分中的分布设置不同限度"
    },
    "option_3": {
      "name": "选项3",
      "description": "成品分析",
      "formula": "Concentration (μg/g) = PDE (μg/day) / Daily Intake (g/day)",
      "applicability": "测量最终药品中各元素浓度"
    }
  },
  "guidance_sections": {
    "potential_sources": {
      "title": "潜在来源 (Section 5.2)",
      "sources": [
        "有意添加的残留杂质（如催化剂）",
        "非有意添加但可能存在的杂质（原料药、水、辅料中）",
        "生产设备引入的杂质",
        "容器密封系统浸出的杂质"
      ],
      "key_considerations": "需评估每个来源对药品中元素杂质的潜在贡献"
    },
    "evaluation": {
      "title": "评估 (Section 5.5)",
      "outcomes": [
        "未识别潜在元素杂质：记录风险评估结论和支持信息",
        "识别潜在元素杂质：考虑是否有多个来源，记录评估结论和支持数据"
      ],
      "data_sources": [
        "先前知识",
        "已发表文献",
        "类似工艺数据",
        "供应商信息或数据",
        "药品组分检测",
        "药品检测"
      ]
    },
    "control_threshold": {
      "title": "控制阈值 (Section 5.6)",
      "definition": "30% of established PDE",
      "application": "如果药品中元素杂质总量持续低于控制阈值，则无需额外控制措施",
      "variability_sources": [
        "分析方法变异",
        "特定来源中元素杂质水平的变异",
        "药品中元素杂质水平的变异"
      ],
      "data_requirements": "3批代表性生产规模批次或6批代表性中试规模批次的数据"
    },
    "speciation": {
      "title": "形态分析 (Section 8)",
      "rule": "可使用总元素含量评估合规性",
      "exception": "如已知特定形态毒性不同，可调整限度"
    },
    "container_closure": {
      "title": "容器密封系统 (Section 5.2 / 8)",
      "solid_forms": "固体制剂中元素浸出概率极低，无需进一步考虑",
      "liquid_semi_solid": "液体制剂和半固体制剂有较高概率在货架期内浸出元素",
      "factors_to_consider": [
        "亲水性/疏水性",
        "离子含量",
        "pH",
        "温度（冷链 vs 室温及工艺条件）",
        "接触表面积",
        "容器/组件组成",
        "终端灭菌",
        "包装工艺",
        "组件灭菌",
        "储存时间"
      ]
    },
    "biotech_products": {
      "title": "生物技术衍生产品 (Section 5.7)",
      "rule": "原料药阶段元素杂质风险较低，通常不需要特定控制",
      "reasons": [
        "元素通常不用作催化剂或试剂",
        "元素在培养基中以痕量添加，无累积且后续处理可显著稀释/去除",
        "典型纯化方案（萃取、色谱、透析/超滤）可将元素清除至可忽略水平"
      ],
      "exception": "含合成结构的生物技术产品（如抗体药物偶联物）需评估小分子组分的元素杂质"
    },
    "lifecycle_management": {
      "title": "生命周期管理 (Section 10)",
      "rule": "变更可能影响元素杂质含量时需重新评估",
      "examples": ["合成路线变更", "辅料供应商变更", "设备变更", "容器密封系统变更"]
    }
  }
}