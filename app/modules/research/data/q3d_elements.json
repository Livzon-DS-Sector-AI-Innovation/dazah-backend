  "cutaneous_route": {
    "description": "皮肤/经皮给药途径（附录5）",
    "cmf": {
      "description": "转换系数 (Concentration Modifying Factor)",
      "default": 10,
      "exceptions": {
        "As": 2,
        "Tl": 1
      }
    },
    "ctcl": {
      "description": "皮肤毒性浓度限度 (Cutaneous Toxicity Concentration Limit)",
      "Ni": 35,
      "Co": 35,
      "notes": "基于致敏性而非全身毒性"
    },
    "calculation": {
      "description": "Cutaneous PDE = Parenteral PDE × CMF",
      "control_threshold": "30% of PDE AND 30% of CTCL"
    }
  },
